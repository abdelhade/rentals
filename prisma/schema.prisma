datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

// ══════════════════════════════════════
//  MASTER DATA
// ══════════════════════════════════════

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String
  measurements MeasurementProfile?
  orders       RentalOrder[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id         String   @id @default(uuid())
  name       String
  phone      String?
  email      String?  @unique
  jobTitle   String?
  salary     Float    @default(0)
  hireDate   DateTime @default(now())
  status     String   @default("ACTIVE") // ACTIVE | INACTIVE
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MeasurementProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  shoulder  Float
  chest     Float
  waist     Float
  hips      Float
  inseam    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  phone     String?
  address   String?
  balance   Float    @default(0)
  suitModels SuitModel[]
  purchases  Purchase[]
  payments   PaymentVoucher[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  phone     String?
  address   String?
  balance   Float    @default(0)
  sales     Sale[]
  receipts  ReceiptVoucher[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Warehouse {
  id        String    @id @default(uuid())
  name      String    @unique
  location  String?
  stocks    Stock[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  sku         String   @unique
  unit        String   @default("piece")
  costPrice   Float    @default(0)
  salePrice   Float    @default(0)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  stocks      Stock[]
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]
  rentalItems   RentalItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Stock {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  quantity    Float     @default(0)
  @@unique([productId, warehouseId])
}

// ══════════════════════════════════════
//  OPERATIONS
// ══════════════════════════════════════

model Purchase {
  id          String         @id @default(uuid())
  supplierId  String
  supplier    Supplier       @relation(fields: [supplierId], references: [id])
  date        DateTime       @default(now())
  total       Float          @default(0)
  paid        Float          @default(0)
  status      String         @default("PENDING") // PENDING | PAID | PARTIAL
  notes       String?
  items       PurchaseItem[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  qty        Float
  unitCost   Float
  total      Float
}

model Sale {
  id          String     @id @default(uuid())
  customerId  String
  customer    Customer   @relation(fields: [customerId], references: [id])
  date        DateTime   @default(now())
  total       Float      @default(0)
  paid        Float      @default(0)
  status      String     @default("PENDING") // PENDING | PAID | PARTIAL
  notes       String?
  items       SaleItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  qty       Float
  unitPrice Float
  total     Float
}

// ══════════════════════════════════════
//  SUIT RENTAL (existing + extended)
// ══════════════════════════════════════

model SuitModel {
  id          String     @id @default(uuid())
  name        String
  description String?
  basePrice   Float
  supplierId  String?
  supplier    Supplier?  @relation(fields: [supplierId], references: [id])
  items       SuitItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model SuitItem {
  id          String        @id @default(uuid())
  sku         String        @unique
  suitModelId String
  suitModel   SuitModel     @relation(fields: [suitModelId], references: [id])
  size        String
  status      String        @default("AVAILABLE")
  orders      RentalOrder[]
  rentalItems RentalItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model RentalOrder {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  suitItemId    String
  suitItem      SuitItem     @relation(fields: [suitItemId], references: [id])
  startDate     DateTime
  endDate       DateTime
  depositStatus String       @default("PENDING")
  depositAmount Float
  orderStatus   String       @default("BOOKED")
  totalPrice    Float
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model RentalItem {
  id          String    @id @default(uuid())
  suitItemId  String
  suitItem    SuitItem  @relation(fields: [suitItemId], references: [id])
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id])
  startDate   DateTime
  endDate     DateTime
  dailyRate   Float
  total       Float
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ══════════════════════════════════════
//  FINANCIAL VOUCHERS
// ══════════════════════════════════════

model ReceiptVoucher {
  id          String    @id @default(uuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  amount      Float
  date        DateTime  @default(now())
  notes       String?
  createdAt   DateTime  @default(now())
}

model PaymentVoucher {
  id          String    @id @default(uuid())
  supplierId  String
  supplier    Supplier  @relation(fields: [supplierId], references: [id])
  amount      Float
  date        DateTime  @default(now())
  notes       String?
  createdAt   DateTime  @default(now())
}
